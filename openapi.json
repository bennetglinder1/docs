{
  "openapi": "3.1.0",
  "info": {
    "title": "Proply Public API",
    "description": "REST API for AI agents and external integrations. Authenticate with your workspace API key.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.goproply.com",
      "description": "Proply cloud"
    }
  ],
  "security": [
    { "apiKey": [] }
  ],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Your workspace API key (also accepted as `Authorization: Bearer <key>`)"
      }
    },
    "schemas": {
      "Contact": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "format": "email" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "name": { "type": "string" },
          "job_title": { "type": "string" },
          "phone": { "type": "string" },
          "linkedin_url": { "type": "string" },
          "notes": { "type": "string" },
          "company": { "type": "string" },
          "company_id": { "type": "string", "format": "uuid" },
          "pipeline_stage": {
            "type": "string",
            "enum": ["identified", "aware", "interested", "evaluating", "client"]
          },
          "icp_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "deal_health_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "last_activity_at": { "type": "string", "format": "date-time" },
          "memory_summary": { "type": "string" }
        }
      },
      "Company": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "domain": { "type": "string" },
          "industry": { "type": "string" },
          "size": { "type": "string" },
          "description": { "type": "string" },
          "linkedin_url": { "type": "string" },
          "website": { "type": "string" }
        }
      },
      "Memory": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "content": { "type": "string" },
          "category": { "type": "string" },
          "source": { "type": "string" },
          "metadata": { "type": "object" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Activity": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "type": { "type": "string" },
          "source": { "type": "string" },
          "occurred_at": { "type": "string", "format": "date-time" },
          "description": { "type": "string" },
          "body": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/v1/contacts": {
      "get": {
        "operationId": "listContacts",
        "summary": "List contacts",
        "description": "Returns a paginated list of contacts for the workspace. Filter by stage, company, or search query.",
        "tags": ["Contacts"],
        "parameters": [
          { "name": "search", "in": "query", "schema": { "type": "string" }, "description": "Full-text search across name, email, and company" },
          { "name": "pipeline_stage", "in": "query", "schema": { "type": "string", "enum": ["identified", "aware", "interested", "evaluating", "client"] }, "description": "Filter by pipeline stage" },
          { "name": "company_id", "in": "query", "schema": { "type": "string", "format": "uuid" }, "description": "Filter by company UUID" },
          { "name": "linkedin_url", "in": "query", "schema": { "type": "string" }, "description": "Exact match on LinkedIn URL" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50, "maximum": 200 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "List of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "contacts": { "type": "array", "items": { "$ref": "#/components/schemas/Contact" } },
                    "total": { "type": "integer" }
                  }
                },
                "example": {
                  "contacts": [
                    {
                      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                      "email": "alex@acmecorp.com",
                      "name": "Alex Chen",
                      "first_name": "Alex",
                      "last_name": "Chen",
                      "job_title": "VP of Engineering",
                      "company": "Acme Corp",
                      "company_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
                      "pipeline_stage": "evaluating",
                      "icp_score": 87,
                      "deal_health_score": 72,
                      "last_activity_at": "2026-05-14T10:30:00Z"
                    }
                  ],
                  "total": 1
                }
              }
            }
          },
          "401": { "description": "Missing or invalid API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "operationId": "createContact",
        "summary": "Create contact",
        "description": "Creates a new contact. Email is required and must be unique within the workspace.",
        "tags": ["Contacts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "first_name": { "type": "string" },
                  "last_name": { "type": "string" },
                  "company": { "type": "string" },
                  "job_title": { "type": "string" },
                  "phone": { "type": "string" },
                  "linkedin_url": { "type": "string" },
                  "notes": { "type": "string" }
                }
              },
              "example": {
                "email": "alex@acmecorp.com",
                "first_name": "Alex",
                "last_name": "Chen",
                "company": "Acme Corp",
                "job_title": "VP of Engineering",
                "linkedin_url": "https://linkedin.com/in/alexchen"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Contact created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } } },
          "409": { "description": "Email already exists", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" }, "example": { "error": "email_already_exists" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/contacts/{id}": {
      "get": {
        "operationId": "getContact",
        "summary": "Get contact",
        "description": "Retrieve a contact by UUID or email address.",
        "tags": ["Contacts"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Contact UUID or email address" }
        ],
        "responses": {
          "200": { "description": "Contact", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" }, "example": { "error": "contact_not_found" } } } }
        }
      },
      "patch": {
        "operationId": "updateContact",
        "summary": "Update contact",
        "description": "Partially update a contact. Only provided fields are changed.",
        "tags": ["Contacts"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": { "type": "string" },
                  "last_name": { "type": "string" },
                  "job_title": { "type": "string" },
                  "company": { "type": "string" },
                  "phone": { "type": "string" },
                  "linkedin_url": { "type": "string" },
                  "notes": { "type": "string" },
                  "pipeline_stage": { "type": "string", "enum": ["identified", "aware", "interested", "evaluating", "client"] }
                }
              },
              "example": { "job_title": "CTO", "pipeline_stage": "evaluating" }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated contact", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } } },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "operationId": "deleteContact",
        "summary": "Delete contact",
        "description": "Permanently deletes a contact and all associated activity.",
        "tags": ["Contacts"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Deleted", "content": { "application/json": { "schema": { "type": "object", "properties": { "deleted": { "type": "boolean" } } }, "example": { "deleted": true } } } },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/contacts/{id}/activity": {
      "get": {
        "operationId": "getContactActivity",
        "summary": "Get contact activity",
        "description": "Returns a tiered activity timeline. Full body for last 7 days, excerpts for 7–30 days, type+date only beyond 30 days.",
        "tags": ["Contacts"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Contact UUID or email" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50, "maximum": 100 } }
        ],
        "responses": {
          "200": {
            "description": "Activity timeline",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "contact_id": { "type": "string", "format": "uuid" },
                    "total": { "type": "integer" },
                    "activities": { "type": "array", "items": { "$ref": "#/components/schemas/Activity" } }
                  }
                },
                "example": {
                  "contact_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                  "total": 3,
                  "activities": [
                    { "id": "act-001", "type": "email_sent", "source": "gmail", "occurred_at": "2026-05-14T10:00:00Z", "description": "Sent proposal follow-up", "body": "Hi Alex, following up on the proposal..." },
                    { "id": "act-002", "type": "calendar_meeting", "source": "google_calendar", "occurred_at": "2026-05-10T14:00:00Z", "description": "30-min discovery call" }
                  ]
                }
              }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/contacts/{id}/context": {
      "get": {
        "operationId": "getContactContext",
        "summary": "Get contact context",
        "description": "Returns a pre-formatted context block — designed to be dropped directly into an AI prompt. Includes stage, scores, recent activity, and key facts.",
        "tags": ["Contacts"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Contact UUID or email" }
        ],
        "responses": {
          "200": {
            "description": "Context block",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "contact_id": { "type": "string", "format": "uuid" },
                    "company_id": { "type": "string", "format": "uuid" },
                    "context": { "type": "string", "description": "Plain-text context block ready to inject into a prompt" },
                    "token_estimate": { "type": "integer" }
                  }
                },
                "example": {
                  "contact_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                  "company_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
                  "context": "Alex Chen · VP of Engineering · Acme Corp\nStage: evaluating  |  ICP: 87  |  Health: 72  |  Last seen: May 14\n\nContext: High-intent buyer, evaluating vendor migration\n\nThis week (2 touchpoints):\n  May 14 — email_sent: Sent proposal follow-up\n  May 12 — calendar_meeting: 30-min discovery call\n\nFacts:\n  [deal] Budget confirmed at $24k ARR\n  [preference] Prefers async over calls",
                  "token_estimate": 128
                }
              }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/companies/{id}": {
      "get": {
        "operationId": "getCompany",
        "summary": "Get company",
        "description": "Retrieve a company profile including enriched firmographic data.",
        "tags": ["Companies"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Company profile", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Company" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" }, "example": { "error": "company_not_found" } } } }
        }
      }
    },
    "/v1/companies/{id}/stakeholders": {
      "get": {
        "operationId": "getCompanyStakeholders",
        "summary": "Get buying committee",
        "description": "Returns all contacts at a company, their derived roles (champion, decision_maker, budget_holder, etc.), and graph edges connecting them.",
        "tags": ["Companies"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Buying committee",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "company": { "$ref": "#/components/schemas/Company" },
                    "contacts": {
                      "type": "array",
                      "items": {
                        "allOf": [
                          { "$ref": "#/components/schemas/Contact" },
                          { "type": "object", "properties": { "roles": { "type": "array", "items": { "type": "string" } } } }
                        ]
                      }
                    },
                    "edges": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "subject": { "type": "string" },
                          "subject_id": { "type": "string" },
                          "relationship": { "type": "string" },
                          "object": { "type": "string" },
                          "object_id": { "type": "string" },
                          "confidence": { "type": "number" }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "company": { "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901", "name": "Acme Corp", "domain": "acmecorp.com", "industry": "SaaS" },
                  "contacts": [
                    { "id": "a1b2c3d4-...", "name": "Alex Chen", "job_title": "VP of Engineering", "pipeline_stage": "evaluating", "icp_score": 87, "roles": ["champion"] },
                    { "id": "c3d4e5f6-...", "name": "Sarah Kim", "job_title": "CFO", "pipeline_stage": "aware", "icp_score": 72, "roles": ["budget_holder"] }
                  ],
                  "edges": [
                    { "subject": "Alex Chen", "relationship": "REPORTS_TO", "object": "Sarah Kim", "confidence": 0.9 }
                  ]
                }
              }
            }
          },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/memories": {
      "get": {
        "operationId": "listMemories",
        "summary": "List memories",
        "description": "Returns workspace-level facts and memories. Optionally filter by category.",
        "tags": ["Memories"],
        "parameters": [
          { "name": "category", "in": "query", "schema": { "type": "string" }, "description": "Filter by category (e.g. `deal`, `preference`, `General`)" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } }
        ],
        "responses": {
          "200": {
            "description": "Memories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "memories": { "type": "array", "items": { "$ref": "#/components/schemas/Memory" } }
                  }
                },
                "example": {
                  "memories": [
                    { "id": "m1", "content": "Budget confirmed at $24k ARR", "category": "deal", "source": "agent", "created_at": "2026-05-14T10:00:00Z" }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v1/memories/search": {
      "get": {
        "operationId": "searchMemories",
        "summary": "Search memories",
        "description": "Semantic search across workspace memories. Optionally scoped to a contact or company.",
        "tags": ["Memories"],
        "parameters": [
          { "name": "q", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search query" },
          { "name": "contact_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "company_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": { "type": "array", "items": { "$ref": "#/components/schemas/Memory" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/memory": {
      "post": {
        "operationId": "createMemory",
        "summary": "Save memory",
        "description": "Store a fact or memory. Attach it to a contact or company via `contact_id` / `company_id`.",
        "tags": ["Memories"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": { "type": "string", "description": "The fact to store" },
                  "category": { "type": "string", "default": "General", "description": "Logical grouping (e.g. `deal`, `preference`, `risk`)" },
                  "source": { "type": "string", "default": "api" },
                  "contact_id": { "type": "string", "format": "uuid" },
                  "company_id": { "type": "string", "format": "uuid" },
                  "metadata": { "type": "object" }
                }
              },
              "example": {
                "content": "Alex confirmed budget at $24k ARR in the May 12 call",
                "category": "deal",
                "contact_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Memory saved", "content": { "application/json": { "schema": { "type": "object", "properties": { "memory": { "$ref": "#/components/schemas/Memory" } } } } } },
          "400": { "description": "content_required" }
        }
      }
    },
    "/v1/memory/{id}": {
      "patch": {
        "operationId": "updateMemory",
        "summary": "Update memory",
        "description": "Update the content or category of an existing memory.",
        "tags": ["Memories"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string" },
                  "category": { "type": "string" },
                  "metadata": { "type": "object" }
                }
              },
              "example": { "content": "Budget confirmed at $30k ARR (revised upward)", "category": "deal" }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "type": "object", "properties": { "memory": { "$ref": "#/components/schemas/Memory" } } } } } },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "operationId": "deleteMemory",
        "summary": "Delete memory",
        "description": "Soft-deletes a memory (sets `is_active: false`). Recoverable from the database.",
        "tags": ["Memories"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Deleted", "content": { "application/json": { "schema": { "type": "object", "properties": { "deleted": { "type": "boolean" } } }, "example": { "deleted": true } } } },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/remember": {
      "post": {
        "operationId": "rememberFact",
        "summary": "Remember (shortcut)",
        "description": "MCP-friendly shortcut for saving a memory. Accepts `text`, `fact`, or `content` as aliases. Can resolve a contact by `email` if you don't have the UUID.",
        "tags": ["Memories"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string" },
                  "text": { "type": "string", "description": "Alias for `content`" },
                  "fact": { "type": "string", "description": "Alias for `content`" },
                  "category": { "type": "string", "default": "General" },
                  "source": { "type": "string", "default": "api" },
                  "contact_id": { "type": "string", "format": "uuid" },
                  "email": { "type": "string", "format": "email", "description": "Resolve contact by email instead of UUID" },
                  "company_id": { "type": "string", "format": "uuid" },
                  "metadata": { "type": "object" }
                }
              },
              "example": {
                "text": "Alex said he's evaluating us against Salesforce",
                "category": "deal",
                "email": "alex@acmecorp.com"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Stored",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "memory": { "$ref": "#/components/schemas/Memory" },
                    "stored": { "type": "integer" },
                    "facts": { "type": "array", "items": { "type": "object", "properties": { "content": { "type": "string" } } } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/search": {
      "post": {
        "operationId": "searchMemoriesPost",
        "summary": "Search (shortcut)",
        "description": "POST variant of memory search — useful when the query is long or includes complex filters. Same results as `GET /v1/memories/search`.",
        "tags": ["Memories"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["q"],
                "properties": {
                  "q": { "type": "string" },
                  "contact_id": { "type": "string", "format": "uuid" },
                  "company_id": { "type": "string", "format": "uuid" },
                  "limit": { "type": "integer", "default": 10 }
                }
              },
              "example": { "q": "budget discussion", "contact_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890" }
            }
          }
        },
        "responses": {
          "200": { "description": "Results", "content": { "application/json": { "schema": { "type": "object", "properties": { "results": { "type": "array", "items": { "$ref": "#/components/schemas/Memory" } } } } } } }
        }
      }
    },
    "/v1/capture": {
      "post": {
        "operationId": "captureActivity",
        "summary": "Log activity",
        "description": "Log a signal or activity event for a contact. The pipeline stage may advance automatically based on DB triggers. Accepts either `contact_id` (UUID) or `email` to identify the contact.",
        "tags": ["Capture"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": { "type": "string", "description": "Activity type (e.g. `email_sent`, `call_completed`, `proposal_viewed`, `website_visit`)" },
                  "contact_id": { "type": "string", "format": "uuid", "description": "Required if `email` not provided" },
                  "email": { "type": "string", "format": "email", "description": "Required if `contact_id` not provided" },
                  "description": { "type": "string" },
                  "source": { "type": "string", "default": "agent", "description": "Integration source label" },
                  "occurred_at": { "type": "string", "format": "date-time", "description": "Defaults to now" },
                  "metadata": { "type": "object" }
                }
              },
              "example": {
                "type": "proposal_viewed",
                "email": "alex@acmecorp.com",
                "description": "Alex opened the proposal 3x in 10 minutes",
                "source": "agent",
                "occurred_at": "2026-05-14T10:30:00Z"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Activity logged",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "activity": { "$ref": "#/components/schemas/Activity" },
                    "contact_id": { "type": "string", "format": "uuid" },
                    "stage_before": { "type": "string" },
                    "stage_after": { "type": "string" },
                    "deal_health_score": { "type": "number" }
                  }
                },
                "example": {
                  "activity": { "id": "act-999", "type": "proposal_viewed", "source": "agent", "occurred_at": "2026-05-14T10:30:00Z", "description": "Alex opened the proposal 3x in 10 minutes" },
                  "contact_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                  "stage_before": "interested",
                  "stage_after": "evaluating",
                  "deal_health_score": 78
                }
              }
            }
          },
          "404": { "description": "Contact not found" },
          "400": { "description": "type_required or contact_id_or_email_required" }
        }
      }
    }
  }
}
