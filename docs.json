              "getting-started/how-it-works",
              "getting-started/quickstart"
            ]
          },
          {
            "group": "Installation",
            "pages": [
              "installation/docker-compose",
              "installation/docker",
              "installation/helm",
              "installation/development-environment",
              "installation/dev-container"
            ]
          },
          {
            "group": "Providers",
            "pages": [
              "providers/overview",
              "providers/add-new-provider",
              {
                "group": "Social Platforms",
                "pages": [
                  "providers/x-twitter",
                  "providers/linkedin",
                  "providers/facebook",
                  "providers/instagram",
                  "providers/youtube",
                  "providers/tiktok",
                  "providers/threads",
                  "providers/bluesky",
                  "providers/mastodon",
                  "providers/reddit",
                  "providers/pinterest"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Public API",
        "groups": [
          {
            "group": "Public API",
            "pages": [
              "public-api/introduction"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "cli/introduction"
            ]
          }
        ]
      },
      {
        "tab": "MCP",
        "groups": [
          {
            "group": "MCP",
            "pages": [
              "mcp/introduction"
            ]
          }
        ]
      },
      {
        "tab": "Developer App (oAuth2)",
        "groups": [
          {
            "group": "Developer App",
            "pages": [
              "developer-app/introduction"
            ]
          }
        ]
      },
      {
        "tab": "Contributing",
        "groups": [
          {
            "group": "Contributing",
            "pages": [
              "contributing/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/bennetglinder1/docs",
          "icon": "github"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.com",
          "icon": "discord"
        },
        {
          "anchor": "YouTube",
          "href": "https://youtube.com",
          "icon": "youtube"
        }
      ]
    }
